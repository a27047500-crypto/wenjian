\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td></tr>\n                                <tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\">音频产品线</td><td class=\"italic\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td><td class=\"relative\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td></tr>\n                                <tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\">相机产品线</td><td class=\"italic\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td><td class=\"relative\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td></tr>\n                                <tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\" style=\"vertical-align: middle;\"><div style=\"text-align: center;\"><span style=\"background-color: rgb(255, 255, 255);\">内通产品线</span></div></td><td class=\"italic\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td><td class=\"relative\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td></tr>\n                                <tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\">专业视频产品线</td><td class=\"italic\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td><td class=\"relative\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td></tr></tbody>\n                        </table>\n                        \n                    </div>\n                </td></tr></tbody>\n            </table>\n        </div>\n\n        <!-- 第3页：目录页 -->\n        <div class=\"a4-page\" id=\"toc-page\">\n            <table class=\"w-full border-0 print-table\" style=\"border:none !important;\">\n                <thead>\n                    <tr>\n                        <td class=\"pb-3 border-0\">\n                            <div class=\"page-header\" contenteditable=\"false\" data-original-contenteditable=\"false\">\n                                <span class=\"header-doc-no z-10 bg-white pr-2\" contenteditable=\"true\" data-original-contenteditable=\"true\">QMS-P-005</span>\n                                <span class=\"absolute left-0 right-0 text-center text-slate-400 font-sans z-0 whitespace-nowrap\" style=\"font-size: 7.5pt !important; letter-spacing: 0px;\" contenteditable=\"true\" data-original-contenteditable=\"true\">本文中的所有信息均为深圳市昊一源科技有限公司内部信息，不得向外传播</span>\n                                <span class=\"page-num-placeholder whitespace-nowrap font-mono z-10 bg-white pl-2\">Page: 3 页</span>\n                            </div>\n                        </td>\n                    </tr>\n                </thead>\n                <tbody><tr><td class=\"align-top border-0\">\n                    <h1 class=\"page-title\" contenteditable=\"true\" data-original-contenteditable=\"true\"><span class=\"section-num\" contenteditable=\"false\" data-original-contenteditable=\"false\">T</span> <span class=\"flex-grow ml-2\">目录</span></h1>\n                    <div class=\"toc-box\" id=\"toc-container\" contenteditable=\"true\" data-original-contenteditable=\"true\"><div class=\"text-center text-slate-400 py-10 font-sans\" contenteditable=\"false\" data-original-contenteditable=\"false\">点击右侧控制台【生成目录】获取</div></div>\n                </td></tr></tbody>\n            </table>\n        </div>\n\n        <!-- 第4页：定义与职责 -->\n        <div class=\"a4-page\">\n            <table class=\"w-full border-0 print-table\" style=\"border:none !important;\">\n                <thead>\n                    <tr>\n                        <td class=\"pb-3 border-0\">\n                            <div class=\"page-header\" contenteditable=\"false\" data-original-contenteditable=\"false\">\n                                <span class=\"header-doc-no z-10 bg-white pr-2\" contenteditable=\"true\" data-original-contenteditable=\"true\">QMS-P-005</span>\n                                <span class=\"absolute left-0 right-0 text-center text-slate-400 font-sans z-0 whitespace-nowrap\" style=\"font-size: 7.5pt !important; letter-spacing: 0px;\" contenteditable=\"true\" data-original-contenteditable=\"true\">本文中的所有信息均为深圳市昊一源科技有限公司内部信息，不得向外传播</span>\n                                <span class=\"page-num-placeholder whitespace-nowrap font-mono z-10 bg-white pl-2\">Page: 4 页</span>\n                            </div>\n                        </td>\n                    </tr>\n                </thead>\n                <tbody><tr><td class=\"align-top border-0\">\n                    <h2 class=\"section-title\" contenteditable=\"true\" data-original-contenteditable=\"true\"><span class=\"section-num\" contenteditable=\"false\" data-original-contenteditable=\"false\">1</span> <span class=\"flex-grow ml-2\">目的</span></h2>\n                    \n                    <div class=\"para-block group/para flex gap-2 items-start\" data-level=\"0\">\n                        <div class=\"para-num text-slate-800 shrink-0 hidden mt-[2px] min-w-[1.5rem]\" contenteditable=\"false\" data-original-contenteditable=\"false\"></div>\n                        <div class=\"text-black p-2 rounded min-h-[1.5em] flex-grow rich-text-content\" contenteditable=\"true\" data-original-contenteditable=\"true\">建立规范、透明的业务流，确保物料按期交付，防范风险。</div>\n                        \n                    </div>\n\n                    <h2 class=\"section-title\" contenteditable=\"true\" data-original-contenteditable=\"true\"><span class=\"section-num\" contenteditable=\"false\" data-original-contenteditable=\"false\">2</span> <span class=\"flex-grow ml-2\">适用范围</span></h2>\n                    \n                    <div class=\"para-block group/para flex gap-2 items-start\" data-level=\"0\">\n                        <div class=\"para-num text-slate-800 shrink-0 hidden mt-[2px] min-w-[1.5rem]\" contenteditable=\"false\" data-original-contenteditable=\"false\"></div>\n                        <div class=\"text-black p-2 rounded min-h-[1.5em] flex-grow rich-text-content\" contenteditable=\"true\" data-original-contenteditable=\"true\">适用于公司所有物料、资产及服务的采购。</div>\n                        \n                    </div>\n\n                    <h2 class=\"section-title\" contenteditable=\"true\" data-original-contenteditable=\"true\"><span class=\"section-num\" contenteditable=\"false\" data-original-contenteditable=\"false\">3</span> <span class=\"flex-grow ml-2\">核心定义</span></h2>\n                    <div class=\"matrix-wrapper group/matrix\">\n                        <table class=\"premium-matrix compact-matrix\">\n                            <thead><tr><th class=\"\" contenteditable=\"true\" style=\"width: 24.9959%;\" data-original-contenteditable=\"true\">专业术语</th><th contenteditable=\"true\" class=\"\" style=\"width: 75.0041%;\" data-original-contenteditable=\"true\">定义与解释</th></tr></thead>\n                            <tbody>\n                                <tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\">合格供应商 (AVL)</td><td class=\"relative\" contenteditable=\"true\" data-original-contenteditable=\"true\">正式列入《合格名录》的供货方。</td></tr>\n                            </tbody>\n                        </table>\n                        \n                    </div>\n\n                    <h2 class=\"section-title\" contenteditable=\"true\" data-original-contenteditable=\"true\"><span class=\"section-num\" contenteditable=\"false\" data-original-contenteditable=\"false\">4</span> <span class=\"flex-grow ml-2\">职责分配</span></h2>\n                    <div class=\"matrix-wrapper group/matrix\">\n                        <table class=\"premium-matrix compact-matrix mb-0\">\n                            <thead><tr><th class=\"\" contenteditable=\"true\" style=\"width: 24.9959%;\" data-original-contenteditable=\"true\">责任主体</th><th contenteditable=\"true\" class=\"\"