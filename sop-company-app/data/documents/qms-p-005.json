ntenteditable=\"true\" data-original-contenteditable=\"true\">赵总监</td><td class=\"text-center relative\" contenteditable=\"true\" data-original-contenteditable=\"true\">王总</td></tr></tbody>\n                        </table>\n                        \n                    </div>\n\n                    <h1 class=\"page-title\" contenteditable=\"true\" data-original-contenteditable=\"true\"><span class=\"section-num\" contenteditable=\"false\" data-original-contenteditable=\"false\">S</span> <span class=\"flex-grow ml-2\">文件会签</span></h1>\n                    <div class=\"matrix-wrapper group/matrix\">\n                        <table class=\"premium-matrix compact-matrix\">\n                            <thead><tr><th class=\"\" contenteditable=\"true\" style=\"width: 24.9959%;\" data-original-contenteditable=\"true\">会签部门</th><th contenteditable=\"true\" class=\"\" style=\"width: 50.0027%;\" data-original-contenteditable=\"true\">会签意见</th><th class=\" text-center\" contenteditable=\"true\" style=\"width: 25.0014%;\" data-original-contenteditable=\"true\">签名 / 日期</th></tr></thead>\n                            <tbody><tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\">总裁办</td><td class=\"italic\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td><td class=\"relative\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td></tr>\n                                <tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\">研发管理中心</td><td class=\"italic\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td><td class=\"relative\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td></tr>\n                                <tr class=\"group/row\"><td contenteditable=\"true\" data-original-contenteditable=\"true\">信息法务中心</td><td class=\"italic\" contenteditable=\"true\" data-original-contenteditable=\"true\"><br></td><td class=\"r