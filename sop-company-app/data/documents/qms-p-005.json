  "html": "\n        <!-- 批注数据存储（随草稿一起保存和恢复） -->\n        <div id=\"comment-store\" style=\"display:none;position:absolute;pointer-events:none;\">[]</div>\n        \n        <!-- 第1页：封面 -->\n        <div class=\"a4-page flex flex-col justify-between\" id=\"page-cover\">\n            <div class=\"flex-shrink-0\">\n                <div class=\"page-header\" contenteditable=\"false\" style=\"border-bottom: none !important;\" data-original-contenteditable=\"false\"></div>\n                <div class=\"flex items-center justify-between border-b border-slate-100 pb-4 min-h-[60px]\">\n                    <div class=\"flex-shrink-0 text-left text-[1.2rem] font-normal tracking-widest text-[#1e293b] leading-snug whitespace-nowrap z-10 font-sans\" contenteditable=\"true\" data-original-contenteditable=\"true\">深圳市昊一源科技有限公司</div>\n                    <div class=\"flex-shrink-0 flex justify-end z-20\"><div class=\"logo-zone\" contenteditable=\"true\" title=\"点击此处，按 Ctrl+V 粘贴Logo。\" data-original-contenteditable=\"true\"></div></div>\n                </div>\n            </div>\n            <div class=\"flex-grow flex flex-col justify-center py-10 relative z-10 min-h-0\">\n                <div class=\"cover-hero-bg bg-[#eff3f8] rounded-[12px] p-10 text-left relative overflow-hidden flex-shrink-0\">\n                    <div class=\"absolute -right-10 -top-10 w-40 h-40 bg-blue-100 rounded-full opacity-50 blur-2xl pointer-events-none\"></div>\n                    <div class=\"absolute -left-10 -bottom-10 w-32 h-32 bg-indigo-100 rounded-full opacity-50 blur-2xl pointer-events-none\"></div>\n                    <div class=\"text-[#60a5fa] font-bold tracking-widest text-xs uppercase mb-4 relative z-10 font-sans\" contenteditable=\"true\" data-original-contenteditable=\"true\">Standard Operating Procedure</div>\n                    <div class=\"flex justify-start items-start mb-4 relative z-10\">\n                        <h1 class=\"text-[3.2rem] font-normal text-slate-800 tracking-wide